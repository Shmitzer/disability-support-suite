{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/caira/**",
              "components/core/**",
              "components/navigation/**",
              "ui_kits/phone/**",
              "ui_kits/tablet/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Bricolage Grotesque|Figtree))/i]",
        "message": "Font not provided by the design system. Available: Bricolage Grotesque, Figtree."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|shape|tone|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: name, size, shape, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:circle|rounded)$/]",
        "message": "<Avatar> shape must be one of 'circle' | 'rounded'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:brand|clay|muted|paper)$/]",
        "message": "<Avatar> tone must be one of 'brand' | 'clay' | 'muted' | 'paper'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|dot|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, dot, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|status|brand|clay|amber)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'status' | 'brand' | 'clay' | 'amber'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|fullWidth|disabled|leftIcon|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, fullWidth, disabled, leftIcon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|padding|radius|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: tone, padding, radius, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:surface|flat|sunk|brand)$/]",
        "message": "<Card> tone must be one of 'surface' | 'flat' | 'sunk' | 'brand'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CategoryTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:category|label|size|key|ref|className|style|children)$/]",
        "message": "<CategoryTile> doesn't accept that prop. Declared props: category, label, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='CategoryTile'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:grid|auto)$/]",
        "message": "<CategoryTile> size must be one of 'grid' | 'auto'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContactRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|role|phone|tone|key|ref|className|style|children)$/]",
        "message": "<ContactRow> doesn't accept that prop. Declared props: name, role, phone, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContactRow'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:brand|clay|muted|paper)$/]",
        "message": "<ContactRow> tone must be one of 'brand' | 'clay' | 'muted' | 'paper'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|multiline|rows|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, multiline, rows."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|tone|size|tagline|style|key|ref|className|style|children)$/]",
        "message": "<Logo> doesn't accept that prop. Declared props: variant, tone, size, tagline, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:lockup|stacked|mark)$/]",
        "message": "<Logo> variant must be one of 'lockup' | 'stacked' | 'mark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:teal|white)$/]",
        "message": "<Logo> tone must be one of 'teal' | 'white'."
      },
      {
        "selector": "JSXOpeningElement[name.name='OnCallButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|key|ref|className|style|children)$/]",
        "message": "<OnCallButton> doesn't accept that prop. Declared props: label."
      },
      {
        "selector": "JSXOpeningElement[name.name='PaperIcon'] > JSXAttribute > JSXIdentifier[name!=/^(?:category|size|style|key|ref|className|style|children)$/]",
        "message": "<PaperIcon> doesn't accept that prop. Declared props: category, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|icon|iconOnly|key|ref|className|style|children)$/]",
        "message": "<SegmentOption> doesn't accept that prop. Declared props: value, label, icon, iconOnly."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
