# Copy to .env for local development:  cp .env.example .env
# The real .env is gitignored — never commit secrets.

# Supabase PostgreSQL (Project Settings → Database). Keep PRIVATE.
#   DATABASE_URL = pooled connection (app, pgbouncer on :6543)
#   DIRECT_URL   = direct, non-pooled connection (:5432) for Prisma Migrate
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-ap-southeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-ap-southeast-2.pooler.supabase.com:5432/postgres"

# Supabase Auth (Phase E). NEXT_PUBLIC_* are intentionally exposed to the browser.
NEXT_PUBLIC_SUPABASE_URL="https://<ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Google Gemini API key — AI note generation. Keep PRIVATE. App runs without it.
GEMINI_API_KEY=""
# Optional: override the Gemini model (defaults to gemini-2.5-flash).
# GEMINI_MODEL="gemini-2.5-flash"

# --- Phase F integrations. Each is OPTIONAL: the feature is inert until its keys
# --- are set, so the app runs fine with all of these blank.

# Shift photos → Supabase Storage. Create a PRIVATE bucket (default "shift-photos").
# Uses SUPABASE_SERVICE_ROLE_KEY (above). Without it, photos fall back to inline.
# SUPABASE_PHOTOS_BUCKET="shift-photos"

# Stripe billing (org-level subscriptions). Keep the secret + webhook signing key
# PRIVATE. Create the product/price + webhook endpoint in the Stripe dashboard.
STRIPE_SECRET_KEY=""
STRIPE_PRICE_ID=""
STRIPE_WEBHOOK_SECRET=""
# Absolute base URL for Stripe redirect (success/cancel/return) URLs.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Transactional email (Resend). App skips sends when blank.
RESEND_API_KEY=""
# EMAIL_FROM="Disability Support Suite <onboarding@resend.dev>"

# Product analytics (PostHog). NEXT_PUBLIC_* are exposed to the browser.
NEXT_PUBLIC_POSTHOG_KEY=""
# NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# Error monitoring (Sentry). SENTRY_DSN = server/edge; NEXT_PUBLIC_SENTRY_DSN = client.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
