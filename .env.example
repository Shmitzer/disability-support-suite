# Copy to .env for local development:  cp .env.example .env
# The real .env is gitignored — never commit secrets.

# Local SQLite database (not a secret). The SessionStart hook defaults to this.
DATABASE_URL="file:./dev.db"

# Google Gemini API key — required only for AI note generation. Keep it PRIVATE:
# set it in your local .env, or as a configured environment variable in your
# Claude Code on the web environment. The app runs without it (AI disabled).
GEMINI_API_KEY=""

# Optional: override the Gemini model (defaults to gemini-2.5-flash).
# GEMINI_MODEL="gemini-2.5-flash"
