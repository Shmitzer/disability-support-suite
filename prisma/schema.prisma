// Prisma schema — Supabase PostgreSQL (Phase 0 cutover).
// Docs: https://pris.ly/d/prisma-schema
//
// Multi-tenant: every data table carries organisationId (Rule 5) and a userId.
// userId holds the owner's Supabase auth uid (auth.uid()) and is NOT NULL on the
// owned tables — the app stamps it via tenantOwner() on every write (Phase E step 2).
// LearnedOption stays nullable (shared global picklist). role/sectorMode are native
// enums; JSON columns use
// Json. Full-text search (ShiftReport.searchVector) and RLS live as checked-in SQL
// (prisma/sql/) applied after `prisma migrate deploy` — see docs/PRODUCTION_CUTOVER.md.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SOLO_WORKER // independent support worker, no org
  WORKER // worker within an organisation
  SUPERVISOR // can view/approve worker notes within org
  ADMIN // full org management (formerly the "ROSTERING" role)
  PARTICIPANT // NDIS participant (future self-managed portal)
  SUPERADMIN // platform-level admin (internal use only)
}

enum SectorMode {
  NDIS
  AGED_CARE
  MENTAL_HEALTH
  COMMUNITY_SERVICES
  EARLY_CHILDHOOD
}

// The tenant. Nullable organisationId on every other table points here by id
// (kept as a scalar for now; wired as a relation when RLS lands in Phase E).
model Organisation {
  id                 String   @id @default(cuid())
  name               String
  sectorMode         SectorMode @default(NDIS)
  stripeCustomerId   String?
  subscriptionStatus String?
  // Max AUTOMATIC AI entry-prompt suggestions per shift (admin-tunable). Manual taps
  // are never capped. See src/lib/org-settings.ts + the auto-suggest in ShiftTracker.
  autoSuggestCap     Int      @default(3)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @default(now()) @updatedAt
}

// A person in the app: support worker, rostering/manager staff, etc. This model is
// also the spec's "User" (account + billing fields live here). Role decides what
// they're allowed to do. (No passwords yet — dev role-switch; real auth in Phase E.)
model Worker {
  id   String @id @default(cuid())
  name String
  role Role @default(WORKER)

  // Account / billing fields (Worker extended into the spec's User). All nullable
  // until real auth (Phase E) and payments (Phase F) are wired.
  supabaseUserId     String?   @unique // set when Supabase Auth is connected
  organisationId     String?           // tenant; null = solo worker (Rule 5)
  referralCode       String?
  referredBy         String?
  stripeCustomerId   String?
  subscriptionStatus String?
  trialEndsAt        DateTime?
  lastSeenVersion    String?

  // Which participants this worker is linked to (controls auction visibility).
  participantLinks WorkerParticipant[]

  // Shift relationships (a worker plays several roles around a shift):
  createdShifts   Shift[]      @relation("ShiftCreatedBy")   // shifts they rostered
  allocatedShifts Shift[]      @relation("ShiftAllocatedTo") // shifts assigned to them
  eventsActed     ShiftEvent[] @relation("EventActor")       // audit-log actions they took

  // Clock-time amendment requests:
  amendmentsRequested ClockAmendmentRequest[] @relation("AmendRequestedBy")
  amendmentsDecided   ClockAmendmentRequest[] @relation("AmendDecidedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

// A person receiving disability support (NDIS participant).
// Sample/dummy data only during development — never real participant data.
model Participant {
  id             String              @id @default(cuid())
  name           String
  ndisNumber     String?             @unique
  userId         String // owning user (e.g. solo worker), for future RLS
  organisationId String?

  // NDIS plan + profile fields (Phase 1 — the coordinator console's participant
  // records). All nullable/additive; populated from the console, never required to
  // run the app. Direct/indirect identifiers here are cleared by anonymiseParticipant.
  preferredName            String?
  dateOfBirth              DateTime?
  pronouns                 String?
  primaryDisability        String?
  communicationNeeds       String?
  culturalNeeds            String?
  address                  String?
  phone                    String?
  email                    String?
  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyContactRelation String?
  gpName                   String?
  gpPhone                  String?
  ndisPlanStart            DateTime?
  ndisPlanEnd              DateTime?
  planManagementType       String? // SELF | PLAN_MANAGED | AGENCY_MANAGED
  planManagerName          String?
  planManagerContact       String?
  supportCoordinator       String?

  // Right-to-erasure (de-identification) tombstones — see src/lib/anonymise.ts.
  anonymisedAt DateTime?
  deletedAt    DateTime?

  notes          ProgressNote[]
  shifts         Shift[]
  workerLinks    WorkerParticipant[] // workers a manager has linked to this person
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @default(now()) @updatedAt
}

// A manager-controlled link between a worker and a participant.
// An auctioned shift is only visible to workers linked to that participant.
model WorkerParticipant {
  id             String      @id @default(cuid())
  worker         Worker      @relation(fields: [workerId], references: [id], onDelete: Cascade)
  workerId       String
  participant    Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  participantId  String
  userId         String
  organisationId String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @default(now()) @updatedAt

  @@unique([workerId, participantId]) // one link per worker/participant pair
}

// A progress note: the worker's rough notes + the AI-generated clean version.
model ProgressNote {
  id             String      @id @default(cuid())
  participant    Participant @relation(fields: [participantId], references: [id])
  participantId  String
  rawNotes       String // what the support worker typed
  generatedNote  String // the cleaned-up NDIS-style note from the AI
  userId         String
  organisationId String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @default(now()) @updatedAt
}

// A work shift, created by rostering staff and worked by a support worker.
// Lifecycle: DRAFT -> OFFERED (auction) or ALLOCATED -> IN_PROGRESS -> COMPLETED.
// (CANCELLED can happen from most states; it's logged for reports.)
model Shift {
  id     String @id @default(cuid())
  status String @default("DRAFT") // DRAFT | OFFERED | ALLOCATED | IN_PROGRESS | COMPLETED | CANCELLED

  participant   Participant @relation(fields: [participantId], references: [id])
  participantId String
  location      String? // where the shift takes place

  // Who rostered it, and who it's for:
  createdBy     Worker  @relation("ShiftCreatedBy", fields: [createdById], references: [id])
  createdById   String
  allocatedTo   Worker? @relation("ShiftAllocatedTo", fields: [allocatedToId], references: [id])
  allocatedToId String? // null until allocated/accepted

  // Planned time (set by roster) vs actual time (set by clock on/off):
  scheduledStart DateTime
  scheduledEnd   DateTime
  clockOnAt      DateTime? // null until the worker clocks on
  clockOffAt     DateTime? // null until the worker clocks off

  // Key lifecycle timestamps for reporting:
  allocatedAt  DateTime?
  cancelledAt  DateTime?
  cancelReason String?

  entries    LogEntry[]              // quick-capture notes during the shift
  events     ShiftEvent[]            // append-only audit log (the compliance trail)
  amendments ClockAmendmentRequest[] // requests to fix clock times
  reports    ShiftReport[]           // AI-generated progress reports for this shift

  idempotencyKey String? @unique // client-generated; prevents duplicate shifts on mobile (Rule 12)
  userId         String
  organisationId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt
}

// Append-only audit log: one row per thing that happened to a shift.
// This is the backbone of NDIS compliance + easy report generation.
model ShiftEvent {
  id      String @id @default(cuid())
  shift   Shift  @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  shiftId String
  // CREATED | OFFERED | ALLOCATED | ACCEPTED | DECLINED | CLOCK_ON | CLOCK_OFF
  // | CANCELLED | AMEND_REQUESTED | AMEND_APPROVED | AMEND_REJECTED
  type           String
  actor          Worker?  @relation("EventActor", fields: [actorId], references: [id])
  actorId        String? // who did it (null for system-generated events)
  detail         String? // optional human-readable / JSON extra context
  userId         String
  organisationId String?
  createdAt      DateTime @default(now()) // when the event happened
  updatedAt      DateTime @default(now()) @updatedAt
}

// A single log entry during a shift (food, toileting, activity, etc).
model LogEntry {
  id             String   @id @default(cuid())
  shift          Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  shiftId        String
  category       String // Meal | Fluids | Activity | Toileting | Hygiene | Meds | Note | Incident
  detail         String? // structured quick-pick facts + amount, e.g. "Water · 250 mL" (null if none)
  notes          String // what the worker typed or dictated
  photos         String? // JSON array of small image data URLs (DEV/DUMMY photos only until Phase 5)
  timestamp      DateTime // when the event happened (not when it was logged)
  idempotencyKey String? @unique // client-generated; prevents duplicate entries on mobile (Rule 12)
  // When an entry was AI-extracted from a free-text Note, this links it back to that
  // source Note (also a LogEntry, category="Note") for provenance/audit. Null for
  // entries captured directly via the chips. Nullable so it doesn't disturb existing
  // rows; the column lands via prisma/sql/note_extraction.sql (NOT auto-applied) —
  // the extraction writer (log-actions.ts) sets it when present and degrades
  // gracefully (entries created unlinked) until that migration is applied.
  derivedFromId  String?
  userId         String
  organisationId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  @@index([derivedFromId])
}

// An AI-generated progress report for one completed shift (task 1g).
// We keep BOTH the warm summary the AI wrote AND the exact source log we fed it
// ("hidden" — not shown by default). That source log is the reusable record other
// parts of the app can later use to generate different reports or fill fields.
// A shift can have several reports over time (e.g. regenerated); the newest wins.
model ShiftReport {
  id        String @id @default(cuid())
  shift     Shift  @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  shiftId   String
  summary   String // the AI-written, person-centred summary (may be hand-edited by staff)
  sourceLog String // the exact compiled log fed to the AI (hidden source of truth)
  model     String? // which AI model produced it (e.g. gemini-2.5-flash)

  // Structured/compliance fields:
  activitiesLog   Json? // structured array of activities (not free text)
  incidentFlag    Boolean @default(false)
  incidentFields  Json? // NDIS mandatory incident fields
  idempotencyKey  String? @unique // prevents duplicate notes on mobile (Rule 12); wired in Phase C
  generatedByModel String?

  // Approval flow (task 1i):
  status         String    @default("DRAFT") // DRAFT | APPROVED
  questions      String? // JSON array of the AI's current clarifying questions (or null)
  clarifications String? // JSON array of {q, a} the worker confirmed and folded in
  approvedAt     DateTime?
  approvedBy     String?
  approvalNotes  String?

  userId         String
  organisationId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt
}

// A self-learning picklist option (drinks, activities, …). `kind` namespaces the
// list. Base options are seeded (APPROVED). When a worker types one that isn't
// listed, we spell-match it to the closest known option if we can; otherwise we
// record it as SUGGESTED and count its uses. Once used a few times it auto-promotes
// to APPROVED and joins everyone's picker. An admin can adjust the list later.
model LearnedOption {
  id             String   @id @default(cuid())
  kind           String // "drink" | "activity" | …
  name           String // canonical display name, e.g. "Coffee"
  status         String   @default("SUGGESTED") // SUGGESTED | APPROVED
  source         String   @default("custom") // seed | custom
  useCount       Int      @default(0) // how many times it's been logged
  sortOrder      Int      @default(100) // seeds keep their curated order first
  userId         String?
  organisationId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt
  lastUsedAt     DateTime @default(now())

  @@unique([kind, name])
}

// A worker's request to fix a missing/wrong clock on/off time.
// Must be approved by a manager — workers can't edit clock times themselves.
model ClockAmendmentRequest {
  id             String    @id @default(cuid())
  shift          Shift     @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  shiftId        String
  requestedBy    Worker    @relation("AmendRequestedBy", fields: [requestedById], references: [id])
  requestedById  String
  field          String // "clockOnAt" | "clockOffAt"
  proposedValue  DateTime // the time the worker says it should be
  reason         String?
  status         String    @default("PENDING") // PENDING | APPROVED | REJECTED
  decidedBy      Worker?   @relation("AmendDecidedBy", fields: [decidedById], references: [id])
  decidedById    String?
  decidedAt      DateTime?
  userId         String
  organisationId String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now()) @updatedAt
}

// Cross-app audit trail for sensitive actions (Rule 9). ShiftEvent remains the
// per-shift compliance log; this captures broader account/billing/admin actions.
model AuditLog {
  id             String   @id @default(cuid())
  action         String // e.g. ROLE_CHANGED | SUBSCRIPTION_UPDATED | REPORT_APPROVED
  actorId        String? // the Worker/User who did it (null = system)
  organisationId String?
  targetType     String // e.g. "Shift" | "Worker" | "ShiftReport"
  targetId       String
  detail         Json? // extra context
  createdAt      DateTime @default(now())

  // Tamper-evidence (hash chain). Each row commits to the row before it within its
  // chain (one chain per organisationId; null-org = the platform/system chain), so
  // any after-the-fact edit or deletion breaks the chain and is detectable. `seq`
  // is the strict append order; `prevHash` is the prior row's `hash` (null at the
  // genesis of a chain); `hash` = sha256(prevHash + canonical(payload)). Nullable
  // so rows written before the live migration (prisma/sql/audit_hash_chain.sql)
  // don't break — see src/lib/audit.ts. Verified by verifyAuditChain().
  seq            BigInt   @unique @default(autoincrement())
  prevHash       String?
  hash           String?

  @@index([organisationId, seq])
}

// ===========================================================================
// RBAC FRAME — Membership, ParticipantAccessGrant, Consent
// ===========================================================================
// The authorization model is the UNION of (a) org-membership roles and (b)
// active participant-scoped grants, resolved by src/lib/access.ts → can(). These
// three tables back that. NOT YET WIRED into the request path (the existing gates
// still read Worker.role); they're the frame the enterprise 32-role / 6-surface
// model and external-carer access slot into. Schema is checked-in SQL applied by
// hand — see prisma/sql/rbac_grants.sql (NOT auto-applied).

// A principal's role WITHIN an organisation. Generalises the single Worker.role +
// organisationId into a many-to-many so one person can hold roles in several orgs
// (and several roles in one). `role` is an org Role (see enum Role).
model Membership {
  id             String   @id @default(cuid())
  workerId       String // the principal (Worker.id)
  organisationId String // the org this role is held in
  role           Role // org role within this org
  status         String   @default("ACTIVE") // ACTIVE | SUSPENDED | REVOKED
  invitedById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  @@unique([workerId, organisationId, role])
  @@index([workerId, status])
  @@index([organisationId, status])
}

// A participant-SCOPED grant of access to a principal who is NOT (necessarily)
// org staff — e.g. an external family carer or a legal guardian. `role` is a
// GrantRole (see GRANT_ROLE_CAPABILITIES), and its capabilities apply ONLY to
// this one participant. A grant is "active" when status = ACTIVE and now is within
// [startsAt, expiresAt] (null bounds = open-ended). Consent backs the grant.
model ParticipantAccessGrant {
  id             String    @id @default(cuid())
  principalId    String // who receives the access (Worker.id)
  participantId  String // the single participant the access is for
  role           String // grant role, e.g. "family_carer_clinical" | "participant_guardian"
  organisationId String? // the participant's org context (for tenant scoping)
  status         String    @default("ACTIVE") // ACTIVE | REVOKED
  grantedById    String? // who granted it (audit)
  consentId      String? // the Consent record that authorises this grant
  startsAt       DateTime?
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now()) @updatedAt

  @@index([principalId, status])
  @@index([participantId, status])
}

// A consent record about a participant — the lawful basis that backs external
// access and sensitive processing (Privacy Act / NDIS). Append-style: a withdrawal
// sets status = WITHDRAWN + withdrawnAt rather than deleting, so the consent
// history is auditable.
model Consent {
  id                   String    @id @default(cuid())
  participantId        String // who the consent is about
  scope                String // e.g. "external_carer_access" | "ai_processing" | "data_sharing"
  grantedToPrincipalId String? // the principal the consent covers, if specific
  status               String    @default("GRANTED") // GRANTED | WITHDRAWN
  method               String? // how it was captured (e.g. "guardian_signed", "verbal_recorded")
  capturedById         String? // the staff member who recorded it
  organisationId       String?
  grantedAt            DateTime  @default(now())
  withdrawnAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @default(now()) @updatedAt

  @@index([participantId, scope, status])
}

// Per-participant care profile (see src/lib/care-needs.ts + docs/design/
// participant-care-profile.md). `conditions` are curated condition tags that SEED
// `supportNeeds` (the resolved functional support-need flags — the source of truth that
// switches capture chips on). `needConfig` holds per-flag config (e.g. IDDSI levels,
// repositioning interval). 1:1 with Participant (kept as a scalar id, like the other
// lightweight relations). NOT yet wired into the request path — see prisma/sql/
// participant_care_profile.sql (NOT auto-applied).
model ParticipantCareProfile {
  id             String   @id @default(cuid())
  participantId  String   @unique
  conditions     String[] // curated condition tags
  supportNeeds   String[] // resolved support-need flags (source of truth)
  needConfig     Json? // per-flag config (IDDSI levels, reposition interval, …)
  organisationId String?
  updatedById    String? // who last edited it (audit)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  @@index([organisationId])
}

// Caira assistant — per-user AI context store (see src/lib/assistant-* + docs/
// caira-assistant.md). Each row is a retrievable snippet the user's assistant may draw
// on. `source` says where it came from; `participantId` (when set) scopes a snippet to
// one person so retrieval can drop it if the user no longer has access. NOT auto-applied
// (prisma/sql/assistant.sql).
model AssistantContext {
  id             String   @id @default(cuid())
  userId         String // owner — whose assistant this feeds
  organisationId String?
  source         String // "upload" | "note" | "learned" | "profile" | "manual"
  title          String?
  content        String // the retrievable text
  participantId  String? // set when the snippet is about a specific participant
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  @@index([userId])
  @@index([participantId])
}

// A stored document/file that feeds the assistant + the participant record. Covers
// provider-attached docs, worker/manager/admin note attachments, third-party uploads,
// personal uploads, and photographed docs (OCR'd to text). `filePath` is a Supabase
// Storage RELATIVE path (Rule 3). `extractedText` is the basis for assistant context;
// on ingest it's chunked into AssistantContext rows. See src/lib/document-actions.ts.
// NOT auto-applied (prisma/sql/documents.sql).
model Document {
  id             String   @id @default(cuid())
  userId         String // who added it (owner)
  organisationId String?
  participantId  String? // about a participant (scopes who can see it)
  source         String // provider_attached | worker_attachment | third_party_upload | personal_upload | photo_capture
  title          String?
  mimeType       String?
  filePath       String? // Supabase Storage relative path (Rule 3); null if text-only
  extractedText  String? // typed/OCR'd text — the basis for assistant context
  status         String   @default("PENDING") // PENDING | READY | INGESTED | FAILED
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  @@index([userId])
  @@index([participantId])
}

// Assistant conversation history (also the raw material for "learn as they use it").
model AssistantMessage {
  id             String   @id @default(cuid())
  userId         String
  organisationId String?
  role           String // "user" | "assistant"
  content        String
  createdAt      DateTime @default(now())

  @@index([userId, createdAt])
}

// #1 Care task / ADL checklist — the plan of tasks for a participant, ticked off per
// shift. See src/lib/care-task-actions.ts. NOT auto-applied (prisma/sql/care_tasks.sql).
model CareTask {
  id             String   @id @default(cuid())
  participantId  String
  organisationId String?
  title          String
  category       String? // e.g. ADL | domestic | community | health
  sortOrder      Int      @default(100)
  active         Boolean  @default(true)
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  @@index([participantId, active])
}

model ShiftTaskCompletion {
  id             String   @id @default(cuid())
  shiftId        String
  careTaskId     String
  status         String // DONE | SKIPPED
  note           String?
  completedById  String?
  organisationId String?
  completedAt    DateTime @default(now())

  @@unique([shiftId, careTaskId])
  @@index([shiftId])
}

// #2 Incident register — first-class incidents with mandatory fields + reportable
// workflow. See src/lib/incident-actions.ts. NOT auto-applied (prisma/sql/incidents.sql).
model Incident {
  id              String    @id @default(cuid())
  participantId   String?
  shiftId         String?
  reportedById    String?
  organisationId  String?
  occurredAt      DateTime
  type            String // physical | behavioural | environmental | medical | other
  severity        String // low | medium | high | critical
  description     String
  immediateAction String?
  notified        Json? // { participant, guardian, supervisor, commission }
  followUp        String?
  reportable      Boolean   @default(false)
  status          String    @default("OPEN") // OPEN | UNDER_REVIEW | CLOSED
  reviewedById    String?
  reviewedAt      DateTime?
  reviewNotes     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt

  @@index([organisationId, status])
  @@index([participantId])
}

// #7 Worker credentials / training (expiry tracking; also gates high-intensity
// competency — see src/lib/credentials.ts). NOT auto-applied (prisma/sql/credentials.sql).
model WorkerCredential {
  id                 String    @id @default(cuid())
  workerId           String
  organisationId     String?
  type               String // first_aid | ndis_worker_screening | <competency keys> | …
  name               String?
  issuedAt           DateTime?
  expiresAt          DateTime?
  evidenceDocumentId String?
  createdById        String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @default(now()) @updatedAt

  @@index([workerId])
  @@index([organisationId, expiresAt])
}

// #5 In-app notifications (recipient-scoped). See src/lib/notifications.ts.
model Notification {
  id             String    @id @default(cuid())
  userId         String // recipient
  organisationId String?
  type           String // shift | meds_due | incident | approval | credential_expiry | general
  title          String
  body           String?
  link           String?
  entityType     String?
  entityId       String?
  readAt          DateTime?
  createdAt      DateTime  @default(now())

  @@index([userId, readAt])
}

// #6 Medication chart (per participant) + eMAR administration events.
model Medication {
  id             String   @id @default(cuid())
  participantId  String
  organisationId String?
  name           String
  dose           String?
  route          String?
  frequency      String?
  scheduleTimes  Json? // e.g. ["08:00","20:00"]
  prn            Boolean  @default(false)
  prnProtocol    String?
  active         Boolean  @default(true)
  notes          String?
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  @@index([participantId, active])
}

model MedicationAdministration {
  id               String    @id @default(cuid())
  medicationId     String
  participantId    String
  shiftId          String?
  organisationId   String?
  status           String // GIVEN | WITHHELD | REFUSED | PRN_GIVEN
  scheduledAt      DateTime?
  administeredAt   DateTime  @default(now())
  administeredById String?
  witnessedById    String?
  dose             String?
  note             String?
  createdAt        DateTime  @default(now())

  @@index([participantId, administeredAt])
  @@index([medicationId])
}

// #11 EVV / visit verification — geo + method captured at clock on/off (AU light).
model VisitVerification {
  id             String   @id @default(cuid())
  shiftId        String
  organisationId String?
  event          String // CLOCK_ON | CLOCK_OFF
  lat            Float?
  lng            Float?
  accuracy       Float?
  method         String   @default("gps") // gps | manual
  capturedById   String?
  createdAt      DateTime @default(now())

  @@index([shiftId])
}

// #8 NDIS plan budget per category + #13 billable line items / claims. Money in
// integer cents. See src/lib/billing-claims.ts (+ actions).
model ParticipantBudget {
  id             String    @id @default(cuid())
  participantId  String
  organisationId String?
  category       String // e.g. core_daily_activities | capacity_building | capital
  allocatedCents Int       @default(0)
  periodStart    DateTime?
  periodEnd      DateTime?
  notes          String?
  createdById    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now()) @updatedAt

  @@index([participantId])
}

model BillableItem {
  id             String   @id @default(cuid())
  participantId  String
  shiftId        String?
  organisationId String?
  category       String? // maps to a budget category
  lineItemCode   String? // NDIS price-guide item number
  description    String
  quantity       Int      @default(1)
  unitPriceCents Int      @default(0)
  amountCents    Int      @default(0)
  date           DateTime
  status         String   @default("DRAFT") // DRAFT | CLAIMED | PAID | REJECTED
  claimRef       String?
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  @@index([participantId, status])
  @@index([organisationId, status])
}

// #12 Care-team messaging (per participant) + shift handover.
model Message {
  id             String   @id @default(cuid())
  participantId  String // scopes the thread to a participant's care team
  organisationId String?
  senderId       String?
  body           String
  createdAt      DateTime @default(now())

  @@index([participantId, createdAt])
}

model ShiftHandover {
  id             String    @id @default(cuid())
  shiftId        String
  participantId  String?
  organisationId String?
  fromWorkerId   String?
  toWorkerId     String?
  body           String
  acknowledgedAt DateTime?
  acknowledgedById String?
  createdAt      DateTime  @default(now())

  @@index([shiftId])
  @@index([participantId, createdAt])
}

// Pre-launch waitlist capture from the public landing page. Deliberately NOT a
// tenant table: people on the waitlist are not users yet, so there is no userId /
// organisationId (the same Rule 5/10 exception LearnedOption notes for global rows).
// Writes go through the Prisma app only; the public Data API is denied by default
// (enable-RLS-no-policy in rls_policies.sql), since this holds raw email addresses.
model WaitlistSignup {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String   @default("landing") // where the signup came from
  createdAt DateTime @default(now())
}
